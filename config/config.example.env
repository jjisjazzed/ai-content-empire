# API Keys Configuration Template
# Copy this file to config/.env and fill in your values
# NEVER commit config/.env to git (it's in .gitignore)

# =============================================================
# CORE LLM — Choose one or both
# =============================================================

# OpenAI (GPT-4o, GPT-4o-mini)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (Gemini 2.0 Flash - FREE tier available)
# Get key: https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# Which LLM to use for scripts/ebooks: openai | gemini | ollama
LLM_PROVIDER=gemini

# =============================================================
# VIDEO STOCK FOOTAGE — Both are FREE
# =============================================================

# Pexels (required for MoneyPrinterTurbo)
# Get key: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay (backup source)
# Get key: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_api_key_here

# =============================================================
# VOICE SYNTHESIS
# =============================================================

# ElevenLabs (free tier: 10,000 chars/month)
# Get key: https://elevenlabs.io
ELEVEN_LABS_API_KEY=your_elevenlabs_api_key_here
ELEVEN_LABS_VOICE_ID=your_preferred_voice_id_here

# Azure TTS (optional, higher quality)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# =============================================================
# VIDEO UPLOAD / SOCIAL PLATFORMS
# =============================================================

# YouTube Data API v3
# Get key: https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here

# TikTok session (via MoneyPrinterTurbo)
TIKTOK_SESSION_ID=your_tiktok_session_id_here

# =============================================================
# DIGITAL PRODUCT STOREFRONTS
# =============================================================

# Gumroad
# Get key: https://app.gumroad.com/settings/advanced
GUMROAD_ACCESS_TOKEN=your_gumroad_token_here

# Etsy (optional)
ETSY_API_KEY=your_etsy_api_key_here
ETSY_API_SECRET=your_etsy_api_secret_here
ETSY_SHOP_ID=your_etsy_shop_id_here

# =============================================================
# RESEARCH & SEO
# =============================================================

# Brave Search API (for market research)
# Get key: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# =============================================================
# PIPELINE SETTINGS
# =============================================================

# Niches to generate content for (comma-separated)
CONTENT_NICHES=credit_repair,personal_finance

# Number of videos to generate per run
VIDEOS_PER_RUN=2

# Video format: portrait (9:16) or landscape (16:9)
VIDEO_FORMAT=portrait

# Video language
VIDEO_LANGUAGE=en

# Output directory for generated videos
OUTPUT_DIR=./output

# Enable auto-upload after generation: true | false
AUTO_UPLOAD=false

# =============================================================
# OPTIONAL: LOCAL LLM via Ollama
# Install: https://ollama.ai  then: ollama pull llama3.2
# =============================================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# =============================================================
# OPTIONAL: n8n Automation
# =============================================================
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your_n8n_api_key_here
